# ==============================================================================
# GoLamb Standard Library (std)
# Core Foundations for Untyped Lambda Calculus Environments
# ==============================================================================

# Core Church Booleans
T  = \t. \f. t
F = \t. \f. f

# Boolean Logic
NOT = \b. b F T
AND = \p. \q. p q p
OR  = \p. \q. p p q
IF  = \b. \t. \e. b t e
XOR = \p. \q. p (NOT q) q

# ------------------------------------------------------------------------------
# Church Numerals
# ------------------------------------------------------------------------------
0 = \f. \x. x
1 = \f. \x. f x
2 = \f. \x. f (f x)
3 = \f. \x. f (f (f x))
4 = \f. \x. f (f (f (f x)))
5 = \f. \x. f (f (f (f (f x))))

# ------------------------------------------------------------------------------
# Church Arithmetic & Comparisons
# ------------------------------------------------------------------------------
SUCC   = \n. \f. \x. f (n f x)
ADD    = \m. \n. \f. \x. m f (n f x)
MULT   = \m. \n. \f. m (n f)
POW    = \b. \e. e b
ISZERO = \n. n (\x. F) T

# Predecessor using the Visser pair shift method
PRED   = \n. \f. \x. n (\g. \h. h (g f)) (\u. x) (\u. u)
SUB    = \m. \n. n PRED m

# Numerical Comparisons
LEQ    = \m. \n. ISZERO (SUB m n)
EQ     = \m. \n. AND (LEQ m n) (LEQ n m)
GT     = \m. \n. NOT (LEQ m n)

# ------------------------------------------------------------------------------
# Data Structures: Pairs & Lists
# ------------------------------------------------------------------------------
PAIR = \x.\y.\f. f x y
FIRST = \p.p T
SECOND = \p. p F

# Lists implemented via pairs (linked lists)
NIL  = \x. T
CONS = \h. \t. PAIR F (PAIR h t)
HEAD = \l. FIRST (SECOND l)
TAIL = \l. SECOND (SECOND l)
ISEMPTY = FIRST

# ------------------------------------------------------------------------------
# Combinators & Fixed Points
# ------------------------------------------------------------------------------
ID    = \x. x
M     = \x. x x
OMEGA = M M

# Normal Order / Call-by-Name (Curry's Y Combinator)
Y = \f. (\x. f (x x)) (\x. f (x x))

# Call-by-Value (Turing's Theta Combinator or Z-Combinator variant)
Z = \f. (\x. f (\v. x x v)) (\x. f (\v. x x v))

# ------------------------------------------------------------------------------
# Recursive Functional Generators
# ------------------------------------------------------------------------------

# Factorial Generator
FACT_GEN = \f. \n. IF (ISZERO n) 1 (MULT n (f (PRED n)))

# Fibonacci Generator
FIB_GEN  = \f. \n. IF (LEQ n 1) n (ADD (f (SUB n 1)) (f (SUB n 2)))

# List Length Generator
LEN_GEN  = \f. \l. IF (ISEMPTY l) 0 (SUCC (f (TAIL l)))

# ==============================================================================
# Operational Strategy Hookups
# Un-comment the line matching your active REPL flag strategy!
# ==============================================================================

# For Normal Order / Call-by-Name / Call-by-Push-Value (Lazy):
FACT = Y FACT_GEN
FIB  = Y FIB_GEN
LEN  = Y LEN_GEN

# For Call-by-Value (Eager):
# FACT = Z FACT_GEN
# FIB  = Z FIB_GEN
# LEN  = Z LEN_GEN